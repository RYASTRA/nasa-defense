# Copy this file to `.env` for local runs. `.env` is gitignored and never committed.

# --- NASA API key (REQUIRED) --------------------------------------------------
# Get a free key in seconds at https://api.nasa.gov/ .
# The watcher hard-fails at startup if this is not set — no DEMO_KEY fallback.
# (In GitHub Actions, set it as the NASA_API_KEY repo secret instead of using .env.)
NASA_API_KEY=your-key-here
